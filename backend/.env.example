# Copier ce fichier en .env et renseigner les valeurs

# Obligatoire — secret JWT (générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=

# Obligatoire — clé API Google Gemini
GEMINI_API_KEY=

# URL du frontend (CORS)
FRONTEND_URL=http://localhost:3000

# Port du serveur backend
PORT=3001

# PostgreSQL (production uniquement)
DATABASE_URL=

# Stripe (optionnel)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth (optionnel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Email SMTP (optionnel)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
